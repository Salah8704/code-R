generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(uuid())
  email             String              @unique
  passwordHash      String
  role              String              @default("student")
  soundEnabled      Boolean             @default(true)
  browserNotify     Boolean             @default(false)
  createdAt         DateTime            @default(now())
  subscriptions     Subscription[]
  attempts          Attempt[]
  series            Series[]
  weaknessScores    WeaknessScore[]
  recommendations   Recommendation[]
  readiness         ReadinessSnapshot[]
  studyBlocks       StudyBlock[]
  blockPauses       BlockPause[]
  examResults       ExamResult[]
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String
  stripeCustomerId     String
  stripeSubscriptionId String?
  stripePriceId        String?
  status               String
  currentPeriodEnd     DateTime?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Question {
  id               String       @id
  theme            String
  subtheme         String
  trapFamily       String
  difficulty       Int
  type             String       @default("qcm")
  prompt           String
  explanationShort String
  explanationLong  String?
  hasImage         Boolean      @default(false)
  imageUrl         String?
  examLike         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  choices          Choice[]
  attempts         Attempt[]
  seriesItems      SeriesItem[]
  examItems        ExamItem[]
  @@index([theme])
  @@index([subtheme])
  @@index([trapFamily])
}

model Choice {
  id         String   @id
  questionId String
  position   Int
  text       String
  isCorrect  Boolean  @default(false)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@index([questionId])
}

model Attempt {
  id              String   @id @default(uuid())
  userId          String
  questionId      String
  chosenChoiceIds Json
  isCorrect       Boolean
  responseTimeMs  Int
  seriesId        String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([userId, questionId])
}

model Series {
  id           String      @id @default(uuid())
  userId       String
  mode         String
  plannedCount Int
  startedAt    DateTime    @default(now())
  endedAt      DateTime?
  studyBlockId String?
  score        Int?
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        SeriesItem[]
  studyBlock   StudyBlock? @relation(fields: [studyBlockId], references: [id], onDelete: SetNull)
}

model SeriesItem {
  id         String   @id @default(uuid())
  seriesId   String
  questionId String
  position   Int
  series     Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([seriesId, position])
}

model ExamResult {
  id          String     @id @default(uuid())
  userId      String
  score       Int
  totalQ      Int        @default(40)
  durationMs  Int?
  completedAt DateTime   @default(now())
  items       ExamItem[]
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, completedAt])
}

model ExamItem {
  id           String     @id @default(uuid())
  examResultId String
  questionId   String
  position     Int
  isCorrect    Boolean
  examResult   ExamResult @relation(fields: [examResultId], references: [id], onDelete: Cascade)
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model WeaknessScore {
  userId    String
  key       String
  keyType   String   @default("trapFamily")
  score     Float    @default(0)
  updatedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([userId, key])
}

model Recommendation {
  id          String   @id @default(uuid())
  userId      String
  generatedAt DateTime @default(now())
  targetTags  Json
  seriesId    String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReadinessSnapshot {
  id         String   @id @default(uuid())
  userId     String
  score      Float
  level      String
  signals    Json
  computedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, computedAt])
}

model StudyBlock {
  id              String       @id @default(uuid())
  userId          String
  blockNumber     Int
  startedAt       DateTime     @default(now())
  endedAt         DateTime?
  seriesCompleted Int          @default(0)
  averageScore    Float?
  status          String       @default("active")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  series          Series[]
  pauses          BlockPause[]
}

model BlockPause {
  id           String     @id @default(uuid())
  userId       String
  studyBlockId String
  startAt      DateTime
  endAt        DateTime
  status       String
  respected    Boolean    @default(false)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyBlock   StudyBlock @relation(fields: [studyBlockId], references: [id], onDelete: Cascade)
}
